#!/bin/sh
# LookBack pre-commit hook.
# Blocks commits that introduce an answer repeat within REUSE_WINDOW_DAYS in any
# public/puzzles/*.json, or that ship an image without valid attribution.
# Skip with `git commit --no-verify` only as an emergency escape hatch.
#
# To install (once per clone): npm run prepare
# Or manually: git config core.hooksPath .githooks

set -e

if git diff --cached --name-only | grep -q '^public/puzzles/.*\.json$'; then
  echo "→ LookBack: linting puzzles…"
  npm run lint:puzzles --silent
fi

# Non-blocking heads-up: how many days of authored daily puzzles remain.
# Runs on every commit (that is when low runway would otherwise go unnoticed).
# Never fails the commit — check:runway always exits 0; the `|| true` is belt-
# and-suspenders so a tooling hiccup can't block you either.
npm run check:runway --silent || true
